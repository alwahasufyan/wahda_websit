# ===================================================================
# متغيرات البيئة المطلوبة — انسخ هذا الملف إلى .env وأكمل القيم
# NEVER commit .env to version control
# ===================================================================

# ── قاعدة البيانات ─────────────────────────────────────────────────
# لتحسين الأداء تحت الضغط: connection_limit بين 5-20 حسب موارد الخادم
DATABASE_URL="postgresql://user:password@localhost:5432/wahda_db?connection_limit=10&pool_timeout=20&connect_timeout=10"

# ── الأمان ─────────────────────────────────────────────────────────
# مفتاح JWT: يجب أن يكون عشوائياً ولا يقل عن 64 حرفاً
# لتوليده: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="replace-with-long-random-secret"

# مفتاح تشفير النسخ الاحتياطي (يجب أن يكون مختلفاً عن JWT_SECRET)
BACKUP_ENCRYPTION_KEY="replace-with-backup-encryption-key"

# مفتاح توقيع روابط المستفيدين
BENEFICIARY_TOKEN_SECRET="replace-with-beneficiary-token-secret"

# ── إعداد المشرف الأول (seed) ──────────────────────────────────────
# تُستخدم مرة واحدة عند تهيئة النظام: npx ts-node prisma/seed.ts
# احذفها من .env بعد التهيئة أو احتفظ بها في مكان آمن
ADMIN_SEED_PASSWORD="replace-with-admin-password"

# ── Redis (اختياري — بدونه يُستخدم fallback في الذاكرة) ────────────
# يُستخدم لمشاركة rate-limit و SSE بين عدة instances
# إذا كان Redis محمياً بكلمة مرور: redis://:YOUR_PASSWORD@localhost:6379
REDIS_URL="redis://localhost:6379"

# ── إعدادات العمل ──────────────────────────────────────────────────
# الرصيد الابتدائي لكل مستفيد جديد بالدينار الليبي (افتراضي: 600)
INITIAL_BALANCE=600
