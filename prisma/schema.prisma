generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Facility {
  id                   String        @id @default(cuid())
  name                 String
  username             String        @unique
  password_hash        String
  is_admin             Boolean       @default(false)
  must_change_password Boolean       @default(false)
  deleted_at           DateTime?
  created_at           DateTime      @default(now())
  transactions         Transaction[]

  @@index([deleted_at])
}

model Beneficiary {
  id                String            @id @default(cuid())
  card_number       String
  name              String
  birth_date        DateTime?
  total_balance     Decimal             @default(600)
  remaining_balance Decimal             @default(600)
  status            BeneficiaryStatus @default(ACTIVE)
  deleted_at        DateTime?
  created_at        DateTime          @default(now())
  transactions      Transaction[]

  @@index([card_number])
  @@index([deleted_at])
}

model Transaction {
  id             String          @id @default(cuid())
  beneficiary_id String
  facility_id    String
  amount         Decimal
  type           TransactionType
  is_cancelled            Boolean      @default(false)
  created_at              DateTime     @default(now())
  original_transaction_id String?
  original_transaction    Transaction? @relation("TransactionCorrection", fields: [original_transaction_id], references: [id])
  corrections             Transaction[] @relation("TransactionCorrection")
  beneficiary             Beneficiary  @relation(fields: [beneficiary_id], references: [id], onDelete: Restrict)
  facility       Facility        @relation(fields: [facility_id], references: [id], onDelete: Restrict)

  @@index([beneficiary_id])
  @@index([facility_id])
  @@index([facility_id, created_at])
  @@index([created_at])
}

model AuditLog {
  id          String   @id @default(cuid())
  facility_id String?
  user        String
  action      String
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([facility_id, created_at])
  @@index([action])
}

model ImportJob {
  id             String          @id @default(cuid())
  created_by     String
  status         ImportJobStatus @default(PENDING)
  payload        Json
  skipped_rows_report Json?
  total_rows     Int             @default(0)
  processed_rows Int             @default(0)
  inserted_rows  Int             @default(0)
  duplicate_rows Int             @default(0)
  failed_rows    Int             @default(0)
  error_message  String?
  started_at     DateTime?
  completed_at   DateTime?
  created_at     DateTime        @default(now())

  @@index([created_by, created_at])
  @@index([status])
}

enum BeneficiaryStatus {
  ACTIVE
  FINISHED
}

enum TransactionType {
  MEDICINE
  SUPPLIES
  CANCELLATION
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
